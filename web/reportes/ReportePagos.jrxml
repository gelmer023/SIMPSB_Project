	<property name="ireport.y" value="0"/>
	<queryString>
		<![CDATA[SELECT
     comisiones.idComisiones as Id,sum(comisiones.`valor`) AS Valor, concat(
     usuario.`nombre` ,
     usuario.`apellido`) as Empleado
FROM
     `empleado` empleado INNER JOIN `comisiones` comisiones ON empleado.`idEmpleado` = comisiones.`idEmpleado`
     INNER JOIN `usuario` usuario ON empleado.`idUsuario` = usuario.`idUsuario` group by comisiones.idEmpleado]]>
	</queryString>
	<field name="Id" class="java.lang.Integer"/>
	<field name="Valor" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="Empleado" class="java.lang.String"/>
