	<queryString>
		<![CDATA[SELECT
     servicios.`nombre` AS NombreSer,
     count(citas.idCita)as NumCitas,citas.`idServicio`AS Servicio
FROM
     `servicios` servicios INNER JOIN `citas` citas ON servicios.`idServicio` = citas.`idServicio` group by citas.idServicio]]>
	</queryString>
	<field name="NombreSer" class="java.lang.String"/>
	<field name="NumCitas" class="java.lang.Long"/>
	<field name="Servicio" class="java.lang.Integer"/>
