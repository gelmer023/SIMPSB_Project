	<parameter name="idUsuario" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     concat(usuario.`nombre`, 
     usuario.`apellido`) as Nombre,
     usuario.`numDocumento` AS numDocumento
FROM
     `usuario` usuario INNER JOIN `empleado` empleado ON usuario.`idUsuario` = empleado.`idUsuario` where usuario.idUsuario=$P{idUsuario}]]>
	</queryString>
