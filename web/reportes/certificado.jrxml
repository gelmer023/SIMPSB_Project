<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="null" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="6d7ad972-998c-4cdf-9407-bd765dd5966b">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="idUsuario" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     concat(usuario.`nombre`,usuario.`apellido`) AS Nombre,
     usuario.`numDocumento` AS numDocumento,
     cargos.`cargo` AS cargos_cargo,
     horariotrabajo.`horaInicio` AS horariotrabajo_horaInicio,
     horariotrabajo.`horaFin` AS horariotrabajo_horaFin
FROM
     `usuario` usuario INNER JOIN `empleado` empleado ON usuario.`idUsuario` = empleado.`idUsuario`
     INNER JOIN `citas` citas ON empleado.`idEmpleado` = citas.`idEmpleado`
     INNER JOIN `cargos` cargos ON empleado.`idCargo` = cargos.`idCargo`
     INNER JOIN `horariotrabajo` horariotrabajo ON empleado.`idHorarioTrabajo` = horariotrabajo.`idHorarioTrabajo`
WHERE
     usuario.idUsuario = $P{idUsuario}]]>
	</queryString>
	<field name="Nombre" class="java.lang.String">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="numDocumento" class="java.lang.Integer">
		<fieldDescription><![CDATA[]]></fieldDescription>
	</field>
	<field name="cargos_cargo" class="java.lang.String"/>
	<field name="horariotrabajo_horaInicio" class="java.sql.Time"/>
	<field name="horariotrabajo_horaFin" class="java.sql.Time"/>
