	<subDataset name="dataset1" uuid="1690f0d1-66c9-440b-b382-ac5737c152b1"/>
	<subDataset name="dataset2" uuid="da32220a-fa33-4a7a-bdb8-f34df1e776d8"/>
	<parameter name="idFactura" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
     concat(usuario.nombre,usuario.apellido) AS Nombre,
     servicios.`nombre` AS ser,
     factura.`subTotal` AS subtotal,
     factura.`valorTotal` AS total,
     factura.`iva` AS iva,
     usuario.`numDocumento` AS Docu,
     citas.`fecha` AS FechaCi,
     serviciojas.`nombreEx` AS serviciojas_nombreEx,
     serviciojas.`ValorExtra` AS serviciojas_ValorExtra,
     serviciojas.`ideX` AS serviciojas_ideX,
     factura.`idFactura` AS factura_idFactura,
     usuario.`nombre` AS usuario_nombre,
     usuario.`apellido` AS usuario_apellido,
     serviciojas.`idExtra` AS serviciojas_idExtra
FROM
     `citas` citas INNER JOIN `factura` factura ON citas.`idCita` = factura.`idCita`
     INNER JOIN `cliente` cliente ON citas.`idCliente` = cliente.`idCliente`
     INNER JOIN `servicios` servicios ON citas.`idServicio` = servicios.`idServicio`
     INNER JOIN `serviciosextra` serviciosextra ON citas.`idCita` = serviciosextra.`idCita`
     INNER JOIN `usuario` usuario ON cliente.`idUsuario` = usuario.`idUsuario`,
     `serviciojas` serviciojas
WHERE
     factura.idFactura = $P{idFactura}
     and serviciojas.`ideX` = $P{idFactura}]]>
	</queryString>
